# =============================================================================
# pixxi CRM AI — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# 🤖 AI Model (Ollama / Gemma)
# -----------------------------------------------------------------------------
# Name of the Gemma model to load in Ollama
GEMMA_MODEL_NAME=gemma3:270m

# Internal Docker network URL of the Ollama container
# In Docker Compose this is the service name; locally use http://localhost:11434
OLLAMA_API_BASE=http://gemma-backend:8080


# -----------------------------------------------------------------------------
# 🌐 Server
# -----------------------------------------------------------------------------
# Port FastAPI/Uvicorn listens on inside the container
PORT=8080

# Public-facing base URL of your deployment (no trailing slash)
# Used as the redirect target after OAuth flows complete
FRONTEND_URL=https://ai.automationdev.app

# Public-facing base URL used when auto-registering the WhatsApp webhook with Meta
# Usually the same as FRONTEND_URL
WEBHOOK_BASE_URL=https://ai.automationdev.app


# -----------------------------------------------------------------------------
# 🔐 Admin Health Endpoint
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If left empty, /admin/health is disabled and returns 403 for all requests.
# -----------------------------------------------------------------------------
ADMIN_HEALTH_KEY=replace_with_64_char_random_hex_string


# -----------------------------------------------------------------------------
# 📱 Meta / WhatsApp Business Cloud API
# Get these from: https://developers.facebook.com → Your App → Settings
# -----------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=your_meta_app_id
FACEBOOK_CLIENT_SECRET=your_meta_app_secret

# Must exactly match the redirect URI registered in your Meta App dashboard
FACEBOOK_REDIRECT_URI=https://ai.automationdev.app/oauth/facebook/callback

# Static fallback verify token for the webhook challenge handshake.
# Per-user tokens (verify_user_<id>) are generated dynamically during OAuth
# and stored in the DB — this is only used for the global fallback.
WHATSAPP_VERIFY_TOKEN=pixxi_verify_token

# Optional: global fallback credentials (used if no per-user token is found in DB)
# Leave empty if all accounts connect via OAuth — the DB token is always preferred.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=


# -----------------------------------------------------------------------------
# 📧 Google / Gmail OAuth (for IMAP email sync)
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must exactly match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://ai.automationdev.app/oauth/google/callback


# -----------------------------------------------------------------------------
# 📬 IMAP Email (global fallback — only used if no per-user config in DB)
# Per-user IMAP credentials are stored in the DB after Gmail OAuth completes.
# These are only needed if you want a single shared inbox.
# -----------------------------------------------------------------------------
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password


# -----------------------------------------------------------------------------
# ☁️ Google Cloud (optional — only needed if deploying to Google Cloud Run/ADK)
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=local-dev
GOOGLE_CLOUD_LOCATION=local


# -----------------------------------------------------------------------------
# 🧪 Testing (set automatically by pytest — DO NOT set in production)
# -----------------------------------------------------------------------------
# TESTING=1
